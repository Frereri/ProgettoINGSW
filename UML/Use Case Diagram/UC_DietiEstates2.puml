@startuml UC_DietiEstates2
title Use Case Diagram – DietiEstates2

left to right direction
skinparam packageStyle rectangle
skinparam actorStyle awesome

actor "Utente\nNon Autenticato" as GUEST
actor "Cliente" as CLI
actor "Agente" as AGE
actor "Gestore" as GES
actor "Amministratore" as ADM
actor "AWS Cognito" as COG <<system>>
actor "Geoapify API" as GEO <<system>>

' ─── ACCESSO ──────────────────────────────────────
rectangle "Accesso" {
    usecase "Registrarsi" as UC_REG
    usecase "Effettuare il Login" as UC_LOGIN
    usecase "Effettuare il Logout" as UC_LOGOUT
}

' ─── RICERCA IMMOBILI ─────────────────────────────
rectangle "Ricerca e Consultazione Immobili" {
    usecase "Visualizzare lista immobili" as UC_LIST
    usecase "Cercare immobili\n(filtri: città, prezzo, contratto)" as UC_SEARCH
    usecase "Visualizzare dettaglio immobile" as UC_DETAIL
}

' ─── OFFERTE ──────────────────────────────────────
rectangle "Gestione Offerte" {
    usecase "Inviare un'offerta" as UC_OFFERTA
    usecase "Visualizzare le proprie offerte" as UC_MY_OFFERTE
    usecase "Rispondere a una controfferta" as UC_RISPOSTA
    usecase "Gestire un'offerta ricevuta\n(accetta / rifiuta / controfferta)" as UC_GESTISCI_OFF
    usecase "Inserire offerta esterna" as UC_OFF_EXT
    usecase "Consultare storico offerta" as UC_STORICO
}

' ─── GESTIONE ACCOUNT ─────────────────────────────
rectangle "Gestione Account" {
    usecase "Cambiare password" as UC_PWD
}

' ─── GESTIONE IMMOBILI ────────────────────────────
rectangle "Gestione Immobili" {
    usecase "Caricare un nuovo immobile" as UC_CARICA
    usecase "Modificare un immobile" as UC_EDIT_IMM
    usecase "Rilevare servizi zona\n(scuole, parchi, trasporti)" as UC_GEO
    usecase "Visualizzare immobili\ndell'agenzia" as UC_IMM_AGE
}

' ─── GESTIONE STAFF ───────────────────────────────
rectangle "Gestione Agenti" {
    usecase "Creare un nuovo agente" as UC_CREA_AGE
    usecase "Modificare un agente" as UC_EDIT_AGE
    usecase "Eliminare un agente" as UC_DEL_AGE
    usecase "Visualizzare i propri agenti" as UC_LIST_AGE
}

' ─── AMMINISTRAZIONE ──────────────────────────────
rectangle "Amministrazione Sistema" {
    usecase "Gestire agenzie\n(crea / modifica / elimina)" as UC_AGENZIE
    usecase "Gestire utenti\n(visualizza / modifica / elimina)" as UC_UTENTI
    usecase "Creare staff\n(Gestore / Supporto)" as UC_CREA_STAFF
}

' ─── RELAZIONI GUEST ──────────────────────────────
GUEST --> UC_REG
GUEST --> UC_LOGIN
GUEST --> UC_LIST
GUEST --> UC_SEARCH
GUEST --> UC_DETAIL
GUEST <|-- CLI
GUEST <|-- AGE
GUEST <|-- GES
GUEST <|-- ADM

' ─── RELAZIONI CLIENTE ────────────────────────────
CLI --> UC_LOGIN
CLI --> UC_LOGOUT
CLI --> UC_OFFERTA
CLI --> UC_MY_OFFERTE
CLI --> UC_RISPOSTA
CLI --> UC_PWD

' ─── RELAZIONI AGENTE ─────────────────────────────
AGE --> UC_LOGOUT
AGE --> UC_CARICA
AGE --> UC_EDIT_IMM
AGE --> UC_IMM_AGE
AGE --> UC_GESTISCI_OFF
AGE --> UC_OFF_EXT
AGE --> UC_STORICO
AGE --> UC_PWD

' ─── RELAZIONI GESTORE ────────────────────────────
GES --> UC_LOGOUT
GES --> UC_CREA_AGE
GES --> UC_EDIT_AGE
GES --> UC_DEL_AGE
GES --> UC_LIST_AGE
GES --> UC_IMM_AGE
GES --> UC_PWD

' ─── RELAZIONI AMMINISTRATORE ─────────────────────
ADM --> UC_LOGOUT
ADM --> UC_AGENZIE
ADM --> UC_UTENTI
ADM --> UC_CREA_STAFF
ADM --> UC_PWD

' ─── SISTEMI ESTERNI ──────────────────────────────
UC_REG ..> COG : <<include>>
UC_LOGIN ..> COG : <<include>>
UC_PWD ..> COG : <<include>>
UC_CREA_AGE ..> COG : <<include>>
UC_CREA_STAFF ..> COG : <<include>>
UC_CARICA ..> UC_GEO : <<include>>
UC_GEO ..> GEO : <<include>>

@enduml
