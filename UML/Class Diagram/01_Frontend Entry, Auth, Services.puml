@startuml CD_Frontend_01_Core
title  Entry, Auth, Services

skinparam classAttributeIconSize 0
skinparam classFontStyle bold
skinparam packageStyle rectangle
skinparam linetype ortho


' ENTRY POINT  


package "Entry Point" {
    class App {
        +render(): JSX
    }
    class ProtectedRoute {
        +allowedRoles: string[]
        +render(): JSX
    }
}


'  CONTEXT / AUTH 

package "Context" {
    class AuthContext {
        +user: User | null
        +login: Function
        +logout: Function
        +loading: boolean
        +checkUser: Function
    }

    class AuthProvider {
        -user: User | null
        -loading: boolean
        +mapGroupsToRole(groups: string[]): string
        +checkUser(): Promise<void>
        +login(): Promise<void>
        +logout(): Promise<void>
        +render(): JSX
    }

    class useAuth <<hook>> {
        +user: User | null
        +login: Function
        +logout: Function
        +loading: boolean
        +checkUser: Function
    }

    class User <<model>> {
        +email: string
        +role: string
        +token: string
    }

    AuthProvider --> AuthContext : provides
    useAuth ..> AuthContext : consumes
    AuthProvider *-- User
}


' SERVICES           


package "Services" {
    class ImmobileService {
        -API_URL: string
        +getAllImmobili(page, size, filters): Promise
        +getImmobileById(id): Promise
    }

    class OffertaService {
        -API_URL: string
        +inviaOfferta(offertaData, token): Promise
        +getMieOfferte(token): Promise
    }

    class gestoreService <<module>> {
        -API_BASE_URL: string
        -apiRequest(endpoint, options): Promise
        +registraNuovoAgente(agenteData): Promise
        +getMieiAgenti(): Promise
        +eliminaAgente(idAgente): Promise
        +aggiornaAgente(idAgente, agenteData): Promise
    }
}


' SHARED UI COMPONENTS       


package "Shared Components" {
    class Navbar {
        +handleAreaPersonale(): void
        +render(): JSX
    }
    class Footer {
        +render(): JSX
    }
    class Logo {
        +width: string
        +height: string
        +render(): JSX
    }
    class Toast {
        +message: string
        +type: string
        +duration: number
        +onClose: Function
        -leaving: boolean
        +handleClose(): void
        +render(): JSX
    }
    class useToast <<hook>> {
        -toast: ToastState
        -timerRef: Ref
        +toastProps: ToastProps
        +showToast(message, type, duration): void
        +hideToast(): void
    }
    class ConfirmModal {
        +open: boolean
        +message: string
        +onConfirm: Function
        +onCancel: Function
        +render(): JSX
    }
    class ChangePasswordForm {
        +styles: object
        +onUpdate: Function
        -pwData: PasswordData
        -loading: boolean
        -feedback: FeedbackState
        +handleSubmit(): Promise<void>
        +render(): JSX
    }
    class ImmobileForm {
        +initialData: ImmobileDTO
        +isGestore: boolean
        +onSave: Function
        -formData: ImmobileFormData
        -agenti: AgenteDTO[]
        -loading: boolean
        +render(): JSX
    }
    class ListaImmobili {
        +styles: object
        +apiUrl: string
        -immobili: ImmobileDTO[]
        -editingProperty: ImmobileDTO
        -loading: boolean
        +fetchImmobili(): Promise<void>
        +handleDelete(id): Promise<void>
        +render(): JSX
    }
}


' RELAZIONI CORE       


App -- AuthProvider
App -- ProtectedRoute
ProtectedRoute --> useAuth : uses
Navbar --> useAuth : uses
Navbar -- Logo

ImmobileForm --> useToast : uses
ImmobileForm -- Toast
ListaImmobili --> useToast : uses
ListaImmobili -- Toast
ListaImmobili -- ImmobileForm
ListaImmobili -- ConfirmModal

@enduml
