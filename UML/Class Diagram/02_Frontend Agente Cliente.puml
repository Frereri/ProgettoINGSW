@startuml CD_Frontend_02_Pages_Pubbliche_Cliente
title Class  Dashboard Agente & Cliente

skinparam classAttributeIconSize 0
skinparam classFontStyle bold
skinparam packageStyle rectangle
skinparam linetype ortho


' RIFERIMENTI ESTERNI    


package "Services (ref)" {
    class ImmobileService <<ref>> {
        +getAllImmobili(page, size, filters): Promise
        +getImmobileById(id): Promise
    }
    class OffertaService <<ref>> {
        +inviaOfferta(offertaData, token): Promise
        +getMieOfferte(token): Promise
    }
}

package "Shared (ref)" {
    class Navbar <<ref>> {}
    class ChangePasswordForm <<ref>> {}
    class ImmobileForm <<ref>> {}
    class Toast <<ref>> {}
    class useToast <<hook ref>> {}
    class TabellaOfferteAgente <<ref>> {}
    class OffertaManualeForm <<ref>> {}
    class StoricoOffertaDettaglio <<ref>> {}
}


' PAGINE PUBBLICHE


package "Pagine " {
    class Dashboard {
        -immobili: ImmobileDTO[]
        -filters: FilterState
        -page: int
        +fetchImmobili(): Promise<void>
        +handleSearch(): void
        +render(): JSX
    }

    class Login {
        -email: string
        -password: string
        -loading: boolean
        +handleLogin(): Promise<void>
        +render(): JSX
    }

    class SignUp {
        -formData: ClienteFormData
        -loading: boolean
        +handleSignUp(): Promise<void>
        +render(): JSX
    }

    class DettagliImmobile {
        -immobile: ImmobileDTO
        -prezzoOfferta: number
        -loading: boolean
        +fetchImmobile(): Promise<void>
        +handleInviaOfferta(): Promise<void>
        +render(): JSX
    }
}


'  DASHBOARD CLIENTE 


package "Dashboard Cliente" {
    class ClienteDashboard {
        -offerte: OffertaDTO[]
        -view: string
        -pwData: PasswordData
        +caricaOfferte(): Promise<void>
        +handleChangePassword(): Promise<void>
        +rispondi(idOfferta, nuovoStato): Promise<void>
        +render(): JSX
    }
}


' DASHBOARD AGENTE    


package "Dashboard Agente" {
    class AgenteDashboard {
        -view: string
        -idAgente: UUID
        +getUserId(): Promise<void>
        +handleSaveProperty(): void
        +handleLogout(): Promise<void>
        +render(): JSX
    }

    class TabellaOfferteAgenteComp {
        +modo: string
        +onVediStorico: Function
        -offerte: OffertaDTO[]
        -caricamento: boolean
        +caricaDati(): Promise<void>
        +gestisciAzione(idOfferta, stato, prezzo): Promise<void>
        +render(): JSX
    }

    class TabellaOfferteRicevute {
        -offerte: OffertaDTO[]
        -loading: boolean
        +caricaOfferte(): Promise<void>
        +gestisciAzione(idOfferta, stato, prezzo): Promise<void>
        +render(): JSX
    }

    class StoricoOffertaDettaglioComp {
        +idOfferta: int
        +onChiudi: Function
        -logs: StoricoOffertaDTO[]
        -loading: boolean
        +render(): JSX
    }

    class OffertaManualeFormComp {
        +styles: object
        +onSave: Function
        -immobili: ImmobileDTO[]
        -formData: OffertaFormData
        -loading: boolean
        +handleSubmit(): Promise<void>
        +render(): JSX
    }
}


'  RELAZIONI     


' Pagine 
Dashboard -- Navbar
Dashboard --> ImmobileService : uses
DettagliImmobile --> ImmobileService : uses
DettagliImmobile --> OffertaService : uses

' Cliente
ClienteDashboard -- ChangePasswordForm
ClienteDashboard --> OffertaService : uses

' Agente
AgenteDashboard -- ImmobileForm
AgenteDashboard --> useToast : uses
AgenteDashboard -- TabellaOfferteAgenteComp
AgenteDashboard -- OffertaManualeFormComp
OffertaManualeFormComp --> useToast : uses
OffertaManualeFormComp -- Toast
TabellaOfferteAgenteComp -- StoricoOffertaDettaglioComp

@enduml
